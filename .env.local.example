# ============================================================
# learn { } with AI — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values:
#
#   cp .env.local.example .env.local
#
# .env.local is excluded from git and will never be committed.
# ============================================================

# ── Database ──────────────────────────────────────────────────
# Set to 'true' only for hosted Vercel deployment with Postgres.
# Leave unset or 'false' for local SQLite (default).
# USE_POSTGRES=true
# ── Cloud LLM Providers ─────────────────────────────────
# OpenAI, Groq, Mistral, and custom endpoints are configured
# via the app UI at /settings/llm — no env vars needed here.
#
# ── Local LLM via Ollama ──────────────────────────────────────
# No API key or env var required for local models.
# Install Ollama: https://ollama.ai
# Then configure via /settings/llm in the app.
#
# ── Install Script ────────────────────────────────────────────
# If you used install.sh to set up the app, this file was
# generated automatically. You only need to edit it if you
# are switching to a different Anthropic API key.
# ============================================================
